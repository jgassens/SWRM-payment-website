{
  "name": "swrm-sponsorship-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "node server/index.js",
    "build": "vite build && cp dist/index.html dist/404.html",
    "start": "NODE_ENV=production node server/index.js",
    "db:migrate": "wrangler d1 migrations apply swrm-payment-store --remote",
    "worker:check": "wrangler check",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "stripe": "^20.1.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "wrangler": "^4.103.0"
  }
}
